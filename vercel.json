{
  "rewrites": [
    { "source": "/descargar", "destination": "/descargar.html" },
    { "source": "/descargar-apk", "destination": "/api/descargar" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/apk", "destination": "/descargar-apk", "permanent": false },
    { "source": "/zona-cliente-latest.apk", "destination": "/descargar-apk", "permanent": false }
  ]
}
